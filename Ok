local function startAntiRagdoll()
    if State.antiRagdollConn then return end
    State.antiRagdollConn = addConn(RunService.Heartbeat:Connect(function()
        if not State.antiRagdollEnabled then return end
        local c = player.Character
        if not c then return end
        local root = c:FindFirstChild("HumanoidRootPart")
        local hum = c:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local st = hum:GetState()
        if st == Enum.HumanoidStateType.Physics or
           st == Enum.HumanoidStateType.Ragdoll or
           st == Enum.HumanoidStateType.FallingDown then
            hum:ChangeState(Enum.HumanoidStateType.Running)
            local cam = Workspace.CurrentCamera
            if cam then cam.CameraSubject = hum end
            pcall(function()
                local pm = player.PlayerScripts:FindFirstChild("PlayerModule")
                if pm then
                    require(pm:FindFirstChild("ControlModule")):Enable()
                end
            end)
            if root then
                root.Velocity = Vector3.zero
                root.RotVelocity = Vector3.zero
            end

            if not ragdollHitCooldown and not ragdollCountdownActive then
                ragdollHitCooldown = true
                ragdollCountdownActive = true
                State.isStealing = true

                task.spawn(function()
                    local COOLDOWN_SEC = 3.0
                    local remaining = COOLDOWN_SEC

                    local liveToast = create("Frame", {
                        AnchorPoint = Vector2.new(0.5, 0),
                        Position = UDim2.new(0.5, 0, 0, -80),
                        Size = UDim2.fromOffset(280, 58),
                        BackgroundColor3 = Color3.fromRGB(14, 18, 27),
                        BackgroundTransparency = 0.12,
                        Parent = toastHolder,
                    })
                    round(liveToast, 18)
                    stroke(liveToast, Color3.fromRGB(255, 255, 255), 0.86, 1)
                    local seq = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Color3.fromRGB(31, 43, 64)),
                        ColorSequenceKeypoint.new(1, Color3.fromRGB(16, 20, 32)),
                    })
                    gradient(liveToast, seq, 90)
                    pad(liveToast, 12, 12, 8, 8)

                    create("TextLabel", {
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 18),
                        Font = Enum.Font.GothamBold,
                        Text = "💥 you've been hit",
                        TextColor3 = Color3.fromRGB(247, 250, 255),
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Parent = liveToast,
                    })
                    local bodyLbl = create("TextLabel", {
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 0, 0, 20),
                        Size = UDim2.new(1, 0, 0, 24),
                        Font = Enum.Font.Gotham,
                        Text = string.format("stealing locked for %.1fs…", remaining),
                        TextWrapped = true,
                        TextColor3 = Color3.fromRGB(255, 194, 102),
                        TextSize = 11,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextYAlignment = Enum.TextYAlignment.Top,
                        Parent = liveToast,
                    })
                    ragdollCDToast = bodyLbl

                    TweenService:Create(liveToast, TweenInfo.new(0.3,
                        Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
                        {Position = UDim2.new(0.5, 0, 0, 0)}):Play()

                    local tickConn
                    tickConn = RunService.Heartbeat:Connect(function(dt)
                        if not ragdollCountdownActive then
                            tickConn:Disconnect()
                            return
                        end
                        remaining = math.max(0, remaining - dt)
                        if bodyLbl and bodyLbl.Parent then
                            if remaining > 0 then
                                bodyLbl.Text = string.format(
                                    "stealing locked — %.1fs remaining", remaining)
                            else
                                bodyLbl.Text = "✅ countdown done - steal now"
                                bodyLbl.TextColor3 = Color3.fromRGB(97, 255, 185)
                            end
                        end
                        if remaining <= 0 then
                            tickConn:Disconnect()
                        end
                    end)
                    task.wait(COOLDOWN_SEC)
                    ragdollHitCooldown = false
                    ragdollCountdownActive = false
                    State.isStealing = false
                    ragdollCDToast = nil

                    task.wait(1.2)
                    local out = TweenService:Create(liveToast, TweenInfo.new(0.25,
                        Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                        {Position = UDim2.new(0.5, 0, 0, -80),
                         BackgroundTransparency = 1})
                    out:Play()
                    out.Completed:Wait()
                    if liveToast and liveToast.Parent then
                        liveToast:Destroy()
                    end
                end)
            end
        end

        for _, obj in ipairs(c:GetDescendants()) do
            if obj:IsA("Motor6D") and not obj.Enabled then
                obj.Enabled = true
            end
        end
    end))
end

