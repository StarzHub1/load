local function createFriendPromptBillboard(prompt)
    if not prompt or State.friendPromptBillboardCache[prompt] then return end
    local parent = prompt.Parent
    if not parent or not parent:IsA("BasePart") then return end

    local billboard = create("BillboardGui", {
        Name = "StarzFriendESP",
        Size = UDim2.new(0, 160, 0, 44),
        AlwaysOnTop = true,
        MaxDistance = 200,
        Adornee = parent,
        Parent = parent,
    })

    local label = create("TextLabel", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        TextSize = 16,
        TextStrokeTransparency = 0.5,
        TextStrokeColor3 = Color3.new(0, 0, 0),
        Parent = billboard,
    })

    local function refreshLabel()
        local obj = (prompt.ObjectText or ""):lower()
        if string.find(obj, "disallow") then
            label.Text = "✅ ALLOWED"
            label.TextColor3 = Color3.fromRGB(50, 255, 50)
        else
            label.Text = "🔒 DISALLOWED"
            label.TextColor3 = Color3.fromRGB(255, 50, 50)
        end
    end

    refreshLabel()

    local bobConn = addConn(RunService.RenderStepped:Connect(function()
        if not billboard.Parent then return end
        billboard.StudsOffsetWorldSpace = Vector3.new(0,
            3.5 + math.sin(tick() * 2) * 0.5, 0)
    end))

    local textConn = prompt:GetPropertyChangedSignal("ObjectText"):Connect(refreshLabel)

    State.friendPromptBillboardCache[prompt] = {
        billboard = billboard,
        bobConn = bobConn,
        textConn = textConn,
    }
end

local function destroyFriendPromptBillboard(prompt)
    local entry = State.friendPromptBillboardCache[prompt]
    if not entry then return end
    pcall(function() entry.bobConn:Disconnect() end)
    pcall(function() entry.textConn:Disconnect() end)
    pcall(function() entry.billboard:Destroy() end)
    State.friendPromptBillboardCache[prompt] = nil
end

local function isFriendPrompt(prompt)
    local text = (prompt.ObjectText or "") .. (prompt.ActionText or "")
    return string.find(text:lower(), "friend") ~= nil
