    local function makeVBtn(text, accent, cb)
        local btn = create("TextButton", {
            AutoButtonColor = false,
            Size = UDim2.new(1 / 2, -3, 1, 0),
            BackgroundColor3 = accent,
            BackgroundTransparency = 0.2,
            Font = Enum.Font.GothamSemibold,
            Text = text,
            TextColor3 = Color3.fromRGB(245, 250, 255),
            TextSize = 11,
            Parent = btnArea
        })
        round(btn, 11)
        stroke(btn, Color3.fromRGB(255, 255, 255), 0.84, 1)
        local seq = ColorSequence.new({
            ColorSequenceKeypoint.new(0, accent:Lerp(Color3.fromRGB(255, 255, 255), 0.18)),
            ColorSequenceKeypoint.new(1, accent)
        })
        gradient(btn, seq, 135)
        local sc = create("UIScale", {Scale = 1, Parent = btn})
        btn.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or
               i.UserInputType == Enum.UserInputType.Touch then
                TweenService:Create(sc, TweenInfo.new(0.08), {Scale = 0.96}):Play()
            end
        end)
        btn.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or
               i.UserInputType == Enum.UserInputType.Touch then
                TweenService:Create(sc, TweenInfo.new(0.14), {Scale = 1}):Play()
            end
        end)
        btn.Activated:Connect(cb)
        return btn
    end

    makeVBtn("🔍 View", Color3.fromRGB(80, 140, 230), doView)
    makeVBtn("↺ Reset", Color3.fromRGB(60, 70, 100), function()
        selectedViewPlayer = nil
        viewPlayerName = nil
