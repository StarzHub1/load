            for _, d in ipairs(gui:GetDescendants()) do
                if d:IsA("TextButton") or d:IsA("ImageButton") then
                    local t = d:IsA("TextButton") and d.Text:lower() or ""
                    if t:find("admin") or t:find("cmd") or t:find("command") then
                        fireButton(d)
                        task.wait(0)
