local function hasToolInList(target, list)
    local c = target and target.Character
    local bp = target and target:FindFirstChildOfClass("Backpack")
    for _, cont in ipairs({c, bp}) do
        if cont then
            for _, obj in ipairs(cont:GetChildren()) do
                if obj:IsA("Tool") or obj:IsA("Model") then
                    local low = obj.Name:lower()
                    for _, tn in ipairs(list) do
                        if low == tn then return true end
                    end
                end
            end
        end
    end
    return false
end

local function getEquippedFlyingTool(target)
    local c = target and target.Character
    local bp = target and target:FindFirstChildOfClass("Backpack")
    for _, cont in ipairs({c, bp}) do
        if cont then
            for _, obj in ipairs(cont:GetChildren()) do
                if obj:IsA("Tool") or obj:IsA("Model") then
                    local low = obj.Name:lower()
                    for _, td in ipairs(FLYING_TOOLS) do
                        if low == td.key then return td end
                    end
                end
            end
        end
    end
    return nil
end

local function isNearStagingCoord(pos)
    for _, v in ipairs(FLASH_TP_STAGING_COORDS) do
        if (pos - v).Magnitude < STAGING_TRIGGER_RADIUS then return true end
    end
    return false
end

local function isNearCarpetPosition(pos)
    for _, cf in ipairs(carpetDefensePositions) do
        if (pos - cf.Position).Magnitude < carpetDefenseThreshold then
            return true
        end
    end
    return false
end

local function findMyPlot()
    local pf = Workspace:FindFirstChild("Plots")
    if not pf then return nil end
    for _, plot in ipairs(pf:GetChildren()) do
        local ps = plot:FindFirstChild("PlotSign")
        local sg = ps and ps:FindFirstChild("SurfaceGui")
        local fr = sg and sg:FindFirstChild("Frame")
        local tl = fr and fr:FindFirstChild("TextLabel")
        if tl and tl.Text:find(player.DisplayName) then
            return plot
        end
    end
    return nil
end

local function getMyPlotPodiums(plot)
    local pods = {}
    local folder = plot and plot:FindFirstChild("AnimalPodiums")
    if not folder then return pods end
    for i = 1, 10 do
        local p = folder:FindFirstChild(tostring(i))
        if p then
            local ok, pos = pcall(function() return p:GetPivot().Position end)
            if ok then pods[i] = pos end
        end
    end
    return pods
end

local function isInsideBase(pos)
    if not State.myPlot then return false end
    local center = State.myPlot:GetPivot().Position
    local horizontalDist = Vector3.new(pos.X - center.X, 0, pos.Z - center.Z).Magnitude
    if horizontalDist >= BASE_HORIZONTAL_RADIUS then return false end
    local relY = pos.Y - center.Y
    for _, band in ipairs(BASE_FLOOR_RANGES) do
        if relY >= band.min and relY <= band.max then return true end
    end
    return false
end

