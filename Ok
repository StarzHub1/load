end)

local hubOpen = true
local function setHubVisible(state)
    hubOpen = state
    hubToggleButton.Text = state and "✕" or "✦"
    if state then
        shell.Visible = true
        shell.Position = UDim2.fromScale(0.5, 0.54)
        TweenService:Create(shell, TweenInfo.new(0.35,
            Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
            {Position = UDim2.fromScale(0.5, 0.5)}):Play()
    else
        local t = TweenService:Create(shell, TweenInfo.new(0.25,
            Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            {Position = UDim2.fromScale(0.5, 0.58)})
        t:Play()
        t.Completed:Connect(function()
            if not hubOpen then shell.Visible = false end
        end)
    end
end

