addConn(RunService.Heartbeat:Connect(function()
    if not State.autoTeleportTimer then return end
    if tick() - lastAutoTPTime < 1 then return end

    local plotsFolder = Workspace:FindFirstChild("Plots")
    if not plotsFolder then return end

    local targetBase = nil
    local targetPlotName = nil

    for plotName, data in pairs(State.baseEspInstances) do
        if data.plot and data.timeValue then
            local plotPos = data.plot:GetPivot().Position
            local isLeft = plotPos.X < -350
            local isRight = plotPos.X >= -350
            if (State.autoTeleportSide == "Left" and isLeft) or
               (State.autoTeleportSide == "Right" and isRight) then
                if data.timeValue == 1 then
                    targetBase = data
                    targetPlotName = plotName
                    break
                end
            end
        end
    end

    if targetBase and targetPlotName ~= lastTriggeredBase then
        lastTriggeredBase = targetPlotName
        lastAutoTPTime = tick()
        if State.autoTeleportSide == "Left" then
            showToast("auto tp timer", "left base at 1s — executing left TP", 2)
            runAutoTP(spot1_sequence, standing2)
        else
            showToast("auto tp timer", "right base at 1s — executing right TP", 2)
            runAutoTP(spot2_sequence, standing1)
        end
    elseif not targetBase then
        lastTriggeredBase = nil
    end
end))

