    local COLLAPSED_H = 48
    local function setMin(state)
        if minimized == state then return end
        minimized = state
        cb.Text = minimized and "+" or "−"
        local ts = minimized and UDim2.new(exX.Scale, exX.Offset, 0, COLLAPSED_H) or
                   UDim2.new(exX.Scale, exX.Offset, exY.Scale, exY.Offset)
        if minimized then
            body.Visible = false
        else
            body.Visible = true
        end
        TweenService:Create(rootPanel, TweenInfo.new(0.2,
            Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
            {Size = ts}):Play()
    end
    cb.Activated:Connect(function()
        if minimized then body.Visible = true end
        setMin(not minimized)
    end)
    attachDrag(hf, rootPanel)
    return {
        Root = rootPanel,
        Body = body,
        SetVisible = function(s)
            rootPanel.Visible = s
            if s and minimized then body.Visible = false end
        end
    }
end

