local function runAutoTP(seq, standingPos)
    if State.isStealing then return end
    waitForCharacter()
    CONFIG.ANTI_STEAL_ACTIVE = true

    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        local carpet = backpack:FindFirstChild("Flying Carpet")
        if carpet and player.Character and
           player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid:EquipTool(carpet)
        end
    end

    local animal = getNearestAnimal()
    if not animal then
        CONFIG.ANTI_STEAL_ACTIVE = false
        showToast("semi tp", "no nearby animal found", 2)
        return
    end

    local prompt = findPrompt(animal)
    if not prompt then
        CONFIG.ANTI_STEAL_ACTIVE = false
        showToast("semi tp", "prompt not found", 2)
        return
    end

    if not InternalStealCache[prompt] then
        buildStealCallbacks(prompt)
    end
    local data = InternalStealCache[prompt]
    if not data then
        CONFIG.ANTI_STEAL_ACTIVE = false
        showToast("semi tp", "failed to cache prompt", 2)
        return
    end

    data.ready = false
    State.isStealing = true
    StealProgress = 0
    CurrentStealTarget = animal

    local tpDone = false
    local hum = player.Character and
                player.Character:FindFirstChildOfClass("Humanoid")
    if hum then hum.AutoRotate = false end

    for _, fn in ipairs(data.holdCallbacks) do
        pcall(task.spawn, fn)
    end

    local STEAL_DURATION = 0.90
    local TP_THRESHOLD = 0.78
    local startTime = tick()

    task.spawn(function()
        while tick() - startTime < STEAL_DURATION do
            StealProgress = (tick() - startTime) / STEAL_DURATION

            if StealProgress >= TP_THRESHOLD and not tpDone then
                tpDone = true
                local hrp = getHRP()
                if hrp then
                    softTP(hrp, seq[1])
                    task.wait(0.16)

                    standTP(hrp, CFrame.new(standingPos) * seq[2].Rotation)
                    task.wait(0.20)

                    local d1 = (hrp.Position - pos1).Magnitude
                    local d2 = (hrp.Position - pos2).Magnitude
                    local finalPos = d1 < d2 and pos1 or pos2
                    local finalCF = CFrame.new(finalPos) * seq[2].Rotation

                    local char = player.Character
                    local anchoredParts = {}
                    if char then
                        for _, part in ipairs(char:GetDescendants()) do
                            if part:IsA("BasePart") and not part.Anchored then
                                part.Anchored = true
                                table.insert(anchoredParts, part)
                            end
                        end
                    end

                    if hrp and hrp.Parent then
                        hrp.CFrame = finalCF
                        hrp.AssemblyLinearVelocity = Vector3.zero
                        hrp.AssemblyAngularVelocity = Vector3.zero
                    end

                    task.spawn(function()
                        task.wait(0.05)
                        for _, part in ipairs(anchoredParts) do
                            if part and part.Parent then
                                part.Anchored = false
                            end
                        end
                    end)

                    local hm = player.Character and
                               player.Character:FindFirstChildOfClass("Humanoid")
                    if hm then hm.AutoRotate = true end
                end
            end

            task.wait()
        end

        StealProgress = 1

        for _, fn in ipairs(data.triggerCallbacks) do
            pcall(task.spawn, fn)
        end

        task.wait(0.05)
        data.ready = true
        State.isStealing = false
        StealProgress = 0
        CurrentStealTarget = nil
        CONFIG.ANTI_STEAL_ACTIVE = false

        local hm2 = player.Character and
                    player.Character:FindFirstChildOfClass("Humanoid")
        if hm2 then hm2.AutoRotate = true end

        applySpeedBoost()
    end)
end

