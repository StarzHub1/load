local function getBaseAllowedStatus(baseSide)
    local baseFolder = workspace:FindFirstChild("Bases")
    if not baseFolder then return false end

    local basePart = baseFolder:FindFirstChild(baseSide == "Left" and "LeftBase" or "RightBase")
    if not basePart then return false end

    for _, desc in ipairs(basePart:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextBox") then
            local text = desc.Text:lower()
            if text:find("allowed") or text:find("open") or text == "0" then
                return true
            end
        end
    end

    return false
end

local function teleportToBaseSide(baseSide)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if baseSide == "Left" then
        runAutoTP(spot1_sequence, standing2)
    elseif baseSide == "Right" then
        runAutoTP(spot2_sequence, standing1)
    end
end

local function enableTeleportOnAllow(baseSide)
    State.teleportOnAllowEnabled = true
    State.teleportOnAllowBase = baseSide

    if State.teleportOnAllowConn then
        for i, conn in ipairs(State.connections) do
            if conn == State.teleportOnAllowConn then
                table.remove(State.connections, i)
                break
            end
        end
        State.teleportOnAllowConn:Disconnect()
    end

    State.teleportOnAllowConn = addConn(RunService.Heartbeat:Connect(function()
        if not State.teleportOnAllowEnabled or State.teleportOnAllowBase == "None" then
            return
        end

        if getBaseAllowedStatus(State.teleportOnAllowBase) then
            teleportToBaseSide(State.teleportOnAllowBase)
        end
    end))
end

local function disableTeleportOnAllow()
    State.teleportOnAllowEnabled = false
    State.teleportOnAllowBase = "None"

    if State.teleportOnAllowConn then
        for i, conn in ipairs(State.connections) do
            if conn == State.teleportOnAllowConn then
                table.remove(State.connections, i)
                break
            end
        end
        State.teleportOnAllowConn:Disconnect()
        State.teleportOnAllowConn = nil
    end
end

local function getBaseCountdown(baseSide)
    local baseFolder = workspace:FindFirstChild("Bases")
    if not baseFolder then return 999 end

    local basePart = baseFolder:FindFirstChild(baseSide == "Left" and "LeftBase" or "RightBase")
    if not basePart then return 999 end

    for _, desc in ipairs(basePart:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextBox") then
            local num = tonumber(desc.Text)
            if num then return num end
        end
    end

    return 999
end

addConn(RunService.Heartbeat:Connect(function()
    local leftCountdown = getBaseCountdown("Left")
    local rightCountdown = getBaseCountdown("Right")

    if leftCountdown <= 1 and leftCountdown > 0 and not State.autoTPLastTeleported.Left then
        runAutoTP(spot1_sequence, standing2)
        State.autoTPLastTeleported.Left = true
        showToast("🎯 auto tp", "teleported to LEFT base at 1s", 2)
    elseif leftCountdown > 1 then
        State.autoTPLastTeleported.Left = false
    end

    if rightCountdown <= 1 and rightCountdown > 0 and not State.autoTPLastTeleported.Right then
        runAutoTP(spot2_sequence, standing1)
        State.autoTPLastTeleported.Right = true
        showToast("🎯 auto tp", "teleported to RIGHT base at 1s", 2)
    elseif rightCountdown > 1 then
        State.autoTPLastTeleported.Right = false
    end
end))

