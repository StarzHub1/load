task.spawn(function()
    while screenGui.Parent do
        task.wait(0.2)
        if State.spamOnStealEnabled and #State.selectedPlayers > 0 then
            local myChar = player.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            if myRoot then
                local myPos = myRoot.Position
                if State.localLastPos then
                    local moved = (myPos - State.localLastPos).Magnitude
                    if moved >= TP_STUD_THRESHOLD then
                        local d1 = (myPos - pos1).Magnitude
                        local d2 = (myPos - pos2).Magnitude
                        if d1 <= 10 or d2 <= 10 then
                            local now = tick()
                            if not State.stealSpamFired and
                               (now - State.lastStealTeleport) > 1 then
                                State.lastStealTeleport = now
                                State.stealSpamFired = true
                                runSpamOnStealSequence()
                            end
                        else
                            State.stealSpamFired = false
                        end
                    end
                end
                State.localLastPos = myPos
            end
        end
        for _, target in ipairs(Players:GetPlayers()) do
            if target ~= player and target.Character then
                local rp = target.Character:FindFirstChild("HumanoidRootPart")
                if rp then
                    local now = tick()
                    local tool = getEquippedFlyingTool(target)
                    local curPos = rp.Position
                    local lastPos = State.lastKnownPositions[target]
                    local moved = lastPos and (curPos - lastPos).Magnitude or 0
                    if tool and moved >= TP_STUD_THRESHOLD and
                       isNearCarpetPosition(curPos) then
                        local lastFire = State.carpetDefenseCooldowns[target] or 0
                        if (now - lastFire) > 1 then
                            State.carpetDefenseCooldowns[target] = now
                            runAutoDefense(target)
                        end
                    end
                    if State.antiTPScamEnabled and
                       hasToolInList(target, PREARM_TOOLS) and
                       moved >= TP_STUD_THRESHOLD and
                       isNearStagingCoord(curPos) then
                        local lastFire = State.preArmFired[target] or 0
                        if (now - lastFire) >= 2 then
                            State.preArmFired[target] = now
                            executeForFeature(target, "antiTP")
                            executeForFeature(target, "antiTP")
                            executeForFeature(target, "antiTP")
                        end
                    end
                    State.lastKnownPositions[target] = curPos
                end
            end
        end
        if State.autoDefenseEnabled and State.myPlot then
            for _, target in ipairs(Players:GetPlayers()) do
                if target ~= player and target.Character then
                    local rp = target.Character:FindFirstChild("HumanoidRootPart")
                    if rp then
                        if isInsideBase(rp.Position) then
                            if not State.playerWasInBase[target] then
                                State.playerWasInBase[target] = true
                                State.baseBreachDefenseTimes[target] = tick()
                                showToast("🚨 breach", target.DisplayName ..
                                    " in base", 2.4)
                                executeForFeature(target, "autoDefense")
                                executeForFeature(target, "autoDefense")
                            else
                                local lastFire = State.baseBreachDefenseTimes[target] or 0
                                if (tick() - lastFire) >= 3 then
                                    State.baseBreachDefenseTimes[target] = tick()
                                    executeForFeature(target, "autoDefense")
                                    executeForFeature(target, "autoDefense")
                                end
                            end
                        else
                            State.playerWasInBase[target] = nil
                        end
                    end
                end
            end
        end
        if State.antiTPScamEnabled then
            local now = tick()
            for _, target in ipairs(State.selectedPlayers) do
                if target and target.Parent == Players and target.Character then
                    local rp = target.Character:FindFirstChild("HumanoidRootPart")
                    if rp then
                        local curPos = rp.Position
                        State.antiTPPositionHistory[target] =
                            State.antiTPPositionHistory[target] or {}
                        local hist = State.antiTPPositionHistory[target]
                        table.insert(hist, curPos)
                        if #hist > 3 then table.remove(hist, 1) end
                        local activeThresh = hasToolInList(target, SPEED_TOOLS) and 15 or
                                             TP_STUD_THRESHOLD
                        local tpDetected = false
                        local landed = nil
                        for i = 1, #hist - 1 do
                            if (hist[#hist] - hist[i]).Magnitude >= activeThresh then
                                tpDetected = true
                                landed = hist[#hist]
                                break
                            end
                        end
                        local lastPos = State.antiTPLastPositions[target]
                        if lastPos and (curPos - lastPos).Magnitude >= activeThresh then
                            tpDetected = true
                            landed = curPos
                        end
                        State.antiTPLastPositions[target] = curPos
                        if tpDetected and landed then
                            local shouldFire = false
                            for _, pp in pairs(State.myPlotAnimalPodiums) do
                                if (landed - pp).Magnitude < antiTPDistanceThreshold then
                                    shouldFire = true
                                    break
                                end
                            end
                            if not shouldFire and isNearCarpetPosition(landed) then
                                shouldFire = true
                            end
                            if not shouldFire and isInsideBase(landed) then
                                shouldFire = true
                            end
                            if not shouldFire and isNearStagingCoord(landed) then
                                shouldFire = true
                            end
                            if not shouldFire and hasToolInList(target, PREARM_TOOLS) and
                               State.myPlot then
                                if (landed - State.myPlot:GetPivot().Position).Magnitude < 60 then
                                    shouldFire = true
                                end
                            end
                            if shouldFire then
                                local lastFire = State.antiTPLastDefenseTimes[target] or 0
                                if (now - lastFire) >= 0.02 then
                                    State.antiTPLastDefenseTimes[target] = now
                                    executeForFeature(target, "antiTP")
                                    executeForFeature(target, "antiTP")
                                    executeForFeature(target, "antiTP")
                                    showToast("🔍 anti tp", target.DisplayName ..
                                        " tp'd near zones", 2.3)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)

