local function createBaseTimerESP(plot, mainPart)
    local old = State.baseEspInstances[plot.Name]
    if old and old.billboard and old.billboard.Parent then
        old.billboard:Destroy()
    end

    local billboard = create("BillboardGui", {
        Name = "StarzBaseTimer_" .. plot.Name,
        Size = UDim2.new(0, 60, 0, 28),
        StudsOffset = Vector3.new(0, 5, 0),
        AlwaysOnTop = true,
        Adornee = mainPart,
        MaxDistance = 1000,
        Parent = plot,
    })

    local label = create("TextLabel", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        TextScaled = true,
        Font = Enum.Font.GothamBold,
        TextColor3 = Color3.fromRGB(255, 230, 60),
        TextStrokeTransparency = 0,
        TextStrokeColor3 = Color3.new(0, 0, 0),
        Text = "...",
        Parent = billboard,
    })

    State.baseEspInstances[plot.Name] = {
        billboard = billboard,
        label = label,
        plot = plot,
        timeValue = nil
    }
    return billboard, label
end

local function updateBaseTimerESP()
    if not State.baseTimerESPEnabled then return end
    local plotsFolder = Workspace:FindFirstChild("Plots")
    if not plotsFolder then return end

    for _, plot in ipairs(plotsFolder:GetChildren()) do
        local purchases = plot:FindFirstChild("Purchases")
        local plotBlock = purchases and purchases:FindFirstChild("PlotBlock")
        local mainPart = plotBlock and plotBlock:FindFirstChild("Main")
        local existing = State.baseEspInstances[plot.Name]

        local timeLabel = mainPart and
            mainPart:FindFirstChild("BillboardGui") and
            mainPart.BillboardGui:FindFirstChild("RemainingTime")

        if timeLabel and mainPart then
            if not existing or not existing.billboard or
               not existing.billboard.Parent then
                local bill, lbl = createBaseTimerESP(plot, mainPart)
                lbl.Text = timeLabel.Text
                local num = tonumber(timeLabel.Text:match("%d+"))
                State.baseEspInstances[plot.Name].timeValue = num
            else
                existing.label.Text = timeLabel.Text
                local num = tonumber(timeLabel.Text:match("%d+"))
                existing.timeValue = num
            end
        else
            if existing and existing.billboard and existing.billboard.Parent then
                existing.billboard:Destroy()
                State.baseEspInstances[plot.Name] = nil
            end
        end
    end
end

local function enableBaseTimerESP()
    State.baseTimerESPEnabled = true
    updateBaseTimerESP()
end

local function disableBaseTimerESP()
    State.baseTimerESPEnabled = false
    for name, data in pairs(State.baseEspInstances) do
        if data.billboard and data.billboard.Parent then
            data.billboard:Destroy()
        end
        State.baseEspInstances[name] = nil
    end
end

