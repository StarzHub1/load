local function createPriorSpamCircle()
    if State.priorSpamCircle then
        State.priorSpamCircle:Destroy()
    end

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local circle = Instance.new("Part")
    circle.Name = "PriorSpamZone"
    circle.Size = Vector3.new(State.priorSpamRadius * 2, 0.5, State.priorSpamRadius * 2)
    circle.CFrame = hrp.CFrame - Vector3.new(0, 3, 0)
    circle.Anchored = true
    circle.CanCollide = false
    circle.Transparency = 0.7
    circle.Color = Color3.fromRGB(34, 139, 34)
    circle.Material = Enum.Material.Neon
    circle.Parent = workspace

    local mesh = Instance.new("CylinderMesh")
    mesh.Parent = circle

    State.priorSpamCircle = circle

    local updateConn
    updateConn = addConn(RunService.Heartbeat:Connect(function()
        if not State.priorSpamEnabled then
            if updateConn then
                for i, conn in ipairs(State.connections) do
                    if conn == updateConn then
                        table.remove(State.connections, i)
                        break
                    end
                end
                updateConn:Disconnect()
            end
            if circle and circle.Parent then
                circle:Destroy()
            end
            return
        end

        local currentChar = player.Character
        local currentHrp = currentChar and currentChar:FindFirstChild("HumanoidRootPart")
        if currentHrp and circle and circle.Parent then
            circle.CFrame = currentHrp.CFrame - Vector3.new(0, 3, 0)
        end
    end))
end

local function checkPlayersInPriorSpamZone()
    if not State.priorSpamEnabled or #State.priorSpamCommands == 0 then return end

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for _, targetPlayer in pairs(Players:GetPlayers()) do
        if targetPlayer ~= player then
            local targetChar = targetPlayer.Character
            local targetHrp = targetChar and targetChar:FindFirstChild("HumanoidRootPart")

            if targetHrp then
                local distance = (hrp.Position - targetHrp.Position).Magnitude

                if distance <= State.priorSpamRadius then
                    for _, cmdName in ipairs(State.priorSpamCommands) do
                        local adminPanel = getAdminPanel()
                        if adminPanel then
                            local playerBtn = nil
                            local dn = targetPlayer.DisplayName
                            local un = targetPlayer.Name
                            for _, d in ipairs(adminPanel:GetDescendants()) do
                                if d:IsA("TextButton") or d:IsA("ImageButton") then
                                    local t = d:IsA("TextButton") and d.Text or ""
                                    if t == "" then
                                        for _, ch in ipairs(d:GetDescendants()) do
                                            if ch:IsA("TextLabel") then
                                                t = ch.Text
                                                break
                                            end
                                        end
                                    end
                                    if t == dn or t:find(dn, 1, true) or
                                       t == un or t:find(un, 1, true) then
                                        playerBtn = d
                                        break
                                    end
                                end
                            end

                            if playerBtn then
                                for _, d in ipairs(adminPanel:GetDescendants()) do
                                    if d:IsA("TextButton") or d:IsA("ImageButton") then
                                        local t = d:IsA("TextButton") and d.Text or ""
                                        if t == "" then
                                            for _, ch in ipairs(d:GetDescendants()) do
                                                if ch:IsA("TextLabel") and ch.Text ~= "" then
                                                    t = ch.Text
                                                    break
                                                end
                                            end
                                        end
                                        if t ~= "" and (t:match("^:") or t:match("^;")) and
                                           findCommandInText(t, cmdName) then
                                            fireButton(playerBtn)
                                            fireButton(d)
                                            break
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end

