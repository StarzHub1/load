    local function computeScamChance(hasFlash, gpCount, accountAgeDays, itemCount)
        local score = 0
        if hasFlash then score = score + 40 end
        if gpCount >= 3 then
            score = score + 20
        elseif gpCount >= 1 then
            score = score + 10
        end
        if accountAgeDays < 30 then
            score = score + 20
        elseif accountAgeDays < 180 then
            score = score + 10
        end
        if itemCount >= 5 then
            score = score + 10
        elseif itemCount >= 2 then
            score = score + 5
        end
        return math.min(score, 99)
    end

    local function doView()
        if not selectedViewPlayer or not selectedViewPlayer.Parent then
            showToast("view", "select a player first", 2)
            return
        end
        clearResults()
        local target = selectedViewPlayer
        local acctAge = "unknown"
        pcall(function() acctAge = target.AccountAge .. " days" end)

        makeInfoRow("username", "@" .. target.Name, Color3.fromRGB(200, 220, 255))
        makeInfoRow("display name", target.DisplayName, Color3.fromRGB(200, 220, 255))
        makeInfoRow("account age", acctAge, Color3.fromRGB(255, 210, 120))
        makeInfoRow("user id", tostring(target.UserId), Color3.fromRGB(160, 180, 210))

        local char = target.Character
        local bp = target:FindFirstChildOfClass("Backpack")
        local inventoryItems = {}
        local hasFlash = false

        local function scanContainer(container)
            if not container then return end
            for _, obj in ipairs(container:GetChildren()) do
                if obj:IsA("Tool") or obj:IsA("Model") then
                    local n = obj.Name
                    table.insert(inventoryItems, n)
                    local low = n:lower()
                    for _, fn in ipairs(DANGER_TOOLS) do
                        if low:find(fn, 1, true) then hasFlash = true end
                    end
                end
            end
        end
        scanContainer(char)
        scanContainer(bp)

        local flashColor = hasFlash and Color3.fromRGB(255, 90, 90) or
                           Color3.fromRGB(97, 255, 185)
        makeInfoRow("flash/fly tools",
            hasFlash and "⚠️ YES — DANGER" or "✓ not found", flashColor)
        makeInfoRow("inventory count", tostring(#inventoryItems),
            Color3.fromRGB(200, 215, 240))

        if #inventoryItems > 0 then
            local sep = create("Frame", {
                Size = UDim2.new(1, 0, 0, 10),
                BackgroundTransparency = 1,
                Parent = resultsList
            })
            create("TextLabel", {
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 0),
                Font = Enum.Font.GothamSemibold,
                Text = "── inventory ──",
                TextColor3 = Color3.fromRGB(130, 150, 185),
                TextSize = 9,
                Parent = sep
            })
            for _, itemName in ipairs(inventoryItems) do
                local ilow = itemName:lower()
                local isDanger = false
                for _, fn in ipairs(DANGER_TOOLS) do
                    if ilow:find(fn, 1, true) then isDanger = true end
                end
                makeInfoRow(itemName, isDanger and "⚠️ danger" or "tool",
                    isDanger and Color3.fromRGB(255, 120, 80) or
                    Color3.fromRGB(180, 200, 230))
            end
        else
            makeInfoRow("inventory", "empty", Color3.fromRGB(130, 145, 170))
        end

        local ownedPasses = {}
        local gpSep = create("Frame", {
            Size = UDim2.new(1, 0, 0, 10),
            BackgroundTransparency = 1,
            Parent = resultsList
        })
        create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            Font = Enum.Font.GothamSemibold,
            Text = "── gamepasses ──",
            TextColor3 = Color3.fromRGB(130, 150, 185),
            TextSize = 9,
            Parent = gpSep
        })
        for _, gp in ipairs(GAMEPASSES_TO_CHECK) do
            local owned = false
            pcall(function()
                owned = MarketplaceService:UserOwnsGamePassAsync(target.UserId, gp.id)
            end)
            if owned then table.insert(ownedPasses, gp.name) end
            makeInfoRow(gp.name, owned and "✓ owned" or "✗ not owned",
                owned and Color3.fromRGB(97, 255, 185) or Color3.fromRGB(140, 155, 180))
        end

        local chance = computeScamChance(hasFlash, #ownedPasses,
            target.AccountAge or 999, #inventoryItems)
        local chanceColor = chance >= 70 and Color3.fromRGB(255, 70, 70) or
                            chance >= 40 and Color3.fromRGB(255, 190, 60) or
                            Color3.fromRGB(97, 255, 185)
        local chSep = create("Frame", {
            Size = UDim2.new(1, 0, 0, 10),
            BackgroundTransparency = 1,
            Parent = resultsList
        })
        create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            Font = Enum.Font.GothamSemibold,
            Text = "── analysis ──",
            TextColor3 = Color3.fromRGB(130, 150, 185),
            TextSize = 9,
            Parent = chSep
        })
        makeInfoRow("⚠️ scam risk", chance .. "%", chanceColor)
        local verdict = chance >= 70 and "HIGH RISK — likely scammer" or
                        chance >= 40 and "MEDIUM — proceed with caution" or
                        "LOW — probably safe"
        makeInfoRow("verdict", verdict, chanceColor)

        showToast("view", "scan complete · @" .. target.Name, 2.2)
    end

