local function makeActionButton(parent, text, accent, callback)
    local btn = create("TextButton", {
        AutoButtonColor = false,
        Size = UDim2.new(1, 0, 0, S.btnH),
        BackgroundColor3 = accent,
        BackgroundTransparency = 0.22,
        Font = Enum.Font.GothamSemibold,
        Text = text,
        TextColor3 = Color3.fromRGB(246, 249, 255),
        TextSize = S.btnTextSize,
        Parent = parent
    })
    round(btn, 13)
    stroke(btn, Color3.fromRGB(255, 255, 255), 0.84, 1)
    local seq = ColorSequence.new({
        ColorSequenceKeypoint.new(0, accent:Lerp(Color3.fromRGB(255, 255, 255), 0.18)),
        ColorSequenceKeypoint.new(1, accent)
    })
    gradient(btn, seq, 135)
    local sc = create("UIScale", {Scale = 1, Parent = btn})
    local function sp(s)
        TweenService:Create(sc, TweenInfo.new(s and 0.08 or 0.14,
            Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {Scale = s and 0.975 or 1}):Play()
        TweenService:Create(btn, TweenInfo.new(s and 0.08 or 0.14,
            Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {BackgroundTransparency = s and 0.12 or 0.22}):Play()
    end
    btn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or
           i.UserInputType == Enum.UserInputType.Touch then
            sp(true)
        end
    end)
    btn.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or
           i.UserInputType == Enum.UserInputType.Touch then
            sp(false)
        end
    end)
    btn.Activated:Connect(function()
        sp(false)
        if callback then callback(btn) end
    end)
    return btn
end

