local function animateStars(stars)
    for _, s in ipairs(stars) do
        task.delay(rng:NextNumber(0, 2), function()
            loopTween(s.Scale, TweenInfo.new(rng:NextNumber(1.8, 3.5),
                Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {Scale = rng:NextNumber(1.08, 1.34)},
                {Scale = rng:NextNumber(0.72, 1)})
        end)
        task.delay(rng:NextNumber(0, 2), function()
            loopTween(s.Inner, TweenInfo.new(rng:NextNumber(1.6, 3.2),
                Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {BackgroundTransparency = 0.64},
                {BackgroundTransparency = 0.86})
        end)
    end
end

