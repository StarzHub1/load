            Position = UDim2.new(0, 8, 0, 0),
            Size = UDim2.new(0.55, 0, 1, 0),
            Font = Enum.Font.GothamSemibold,
            Text = label,
            TextColor3 = Color3.fromRGB(240, 245, 255),
            TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = row
        })
        create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0.55, 0, 0, 0),
            Size = UDim2.new(0.45, -8, 1, 0),
            Font = Enum.Font.Gotham,
            Text = val,
            TextColor3 = valColor or Color3.fromRGB(180, 197, 222),
            TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent = row
        })
    end
    for _, cmd in ipairs(ALL_COMMANDS) do
        local fired = State.cmdLastFired[cmd.name] or 0
        local rem = fired > 0 and math.max(0, cmd.cd - (tick() - fired)) or 0
        local rdy = rem <= 0
        makeRow(cmd.emoji .. " " .. cmd.name,
            rdy and "ready" or string.format("%.2fs", rem),
            rdy and Color3.fromRGB(97, 255, 185) or Color3.fromRGB(255, 194, 102))
    end
    makeRow("admin found", State.adminPanelState.detected and "yes" or "no",
        State.adminPanelState.detected and Color3.fromRGB(97, 255, 185) or
        Color3.fromRGB(255, 100, 100))
    makeRow("last target",
        State.adminPanelState.lastTarget ~= "" and State.adminPanelState.lastTarget or "--",
        Color3.fromRGB(180, 197, 222))
    makeRow("last cmd",
        State.adminPanelState.lastCommand ~= "" and State.adminPanelState.lastCommand or "--",
        Color3.fromRGB(180, 197, 222))
    makeRow("steal lock", formatCD(secondsRemaining(State.lastStealTeleport, 1)),
        Color3.fromRGB(180, 197, 222))
    for _, p in ipairs(State.selectedPlayers) do
        if p and p.Parent == Players then
            makeRow("antiTP " .. p.DisplayName,
                formatCD(secondsRemaining(State.antiTPLastDefenseTimes[p], 0.02)),
                Color3.fromRGB(180, 197, 222))
            makeRow("carpet " .. p.DisplayName,
                formatCD(secondsRemaining(State.carpetDefenseCooldowns[p], 1)),
                Color3.fromRGB(180, 197, 222))
            makeRow("preArm " .. p.DisplayName,
                formatCD(secondsRemaining(State.preArmFired[p], 2)),
                Color3.fromRGB(180, 197, 222))
        end
    end
end

local function toggleSelectedPlayer(target)
    if State.selectedSet[target] then
        State.selectedSet[target] = nil
        for i, p in ipairs(State.selectedPlayers) do
            if p == target then
                table.remove(State.selectedPlayers, i)
                break
            end
        end
    else
        if #State.selectedPlayers >= 2 then
            showToast("targets", "max 2 targets", 2)
            return
        end
        State.selectedSet[target] = true
        table.insert(State.selectedPlayers, target)
        task.spawn(function() preCachePlayer(target) end)
    end
end

