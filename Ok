local function executeForFeature(targetPlayer, featureKey)
    if not ownsAdminPanel then return false end
    local cfg = commandConfig[featureKey]
    if not cfg then return false end
    local adminPanel = getAdminPanel()
    if not adminPanel then return false end
    local playerButton = nil
    local dn = targetPlayer.DisplayName
    local un = targetPlayer.Name
    for _, d in ipairs(adminPanel:GetDescendants()) do
        if d:IsA("TextButton") or d:IsA("ImageButton") then
            local t = d:IsA("TextButton") and d.Text or ""
            if t == "" then
                for _, ch in ipairs(d:GetDescendants()) do
                    if ch:IsA("TextLabel") then
                        t = ch.Text
                        break
                    end
                end
            end
            if t == dn or t:find(dn, 1, true) or t == un or t:find(un, 1, true) then
                playerButton = d
                break
            end
        end
    end
    if not playerButton then return false end
    for _, cmd in ipairs(ALL_COMMANDS) do
        if cfg[cmd.name] then
            for _, d in ipairs(adminPanel:GetDescendants()) do
                if d:IsA("TextButton") or d:IsA("ImageButton") then
                    local t = d:IsA("TextButton") and d.Text or ""
                    if t == "" then
                        for _, ch in ipairs(d:GetDescendants()) do
                            if ch:IsA("TextLabel") and ch.Text ~= "" then
                                t = ch.Text
                                break
                            end
                        end
                    end
                    if t ~= "" and (t:match("^:") or t:match("^;")) and
                       findCommandInText(t, cmd.name) then
                        fireButton(playerButton)
                        fireButton(d)
                        State.cmdLastFired[cmd.name] = tick()
                        State.adminPanelState.lastTarget = targetPlayer.DisplayName
                        State.adminPanelState.lastCommand = cmd.name
                        break
                    end
                end
            end
        end
    end
    return true
end

