local function makeStarField(parent, count)
    local holder = create("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Parent = parent
    })
    local stars = {}
    for i = 1, count do
        local sz = rng:NextInteger(1, 3)
        local tr = rng:NextNumber(0, 1)
        local tint = tr > 0.8 and Color3.fromRGB(255, 244, 222) or
            (tr > 0.55 and Color3.fromRGB(206, 226, 255) or Color3.fromRGB(250, 252, 255))
        local cont = create("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.fromScale(rng:NextNumber(0.05, 0.95),
                rng:NextNumber(0.05, 0.95)),
            Size = UDim2.fromOffset(18, 18),
            BackgroundTransparency = 1,
            Parent = holder
        })
        local scale = create("UIScale", {
            Scale = rng:NextNumber(0.75, 1.1),
            Parent = cont
        })
        local glow = create("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.fromScale(0.5, 0.5),
            Size = UDim2.fromOffset(8 + sz * 3, 8 + sz * 3),
            BackgroundColor3 = tint,
            BackgroundTransparency = 0.94,
            Parent = cont
        })
        round(glow, 999)
        local inner = create("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.fromScale(0.5, 0.5),
            Size = UDim2.fromOffset(4 + sz, 4 + sz),
            BackgroundColor3 = tint,
            BackgroundTransparency = 0.8,
            Parent = cont
